{
  "name": "@hippodid/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the HippoDid AI character memory API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hippodid",
    "ai",
    "memory",
    "character",
    "agent",
    "rag",
    "sdk"
  ],
  "author": "SameThoughts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SameThoughts/hippodid-node.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
